#include <stdio.h>
#include <stdbool.h> // Para usar el tipo de dato bool

int main() {
    int N = 1000; 
    int count_primos = 0;
    long long suma_primos = 0;
    int primos_pares = 0;
    int primos_impares = 0;

    if (N >= 2) {
        // El 2 es el único primo par, lo manejamos por separado
        count_primos++;
        suma_primos += 2;
        primos_pares++;
    }

    // Iteramos solo sobre números impares desde 3
    for (int m = 3; m <= N; m += 2) {
        bool es_primo = true;

        // Probamos divisores impares hasta la raíz cuadrada de m
        for (int d = 3; d * d <= m; d += 2) {
            if (m % d == 0) {
                es_primo = false;
                break; // Salimos del bucle inmediatamente
            }
        }

        if (es_primo) {
            count_primos++;
            suma_primos += m;
            primos_impares++;
        }
    }

    printf("Primos encontrados: %d\n", count_primos);
    printf("Suma de primos: %lld\n", suma_primos);
    printf("Primos pares: %d\n", primos_pares);
    printf("Primos impares: %d\n", primos_impares);

    return 0;
}
